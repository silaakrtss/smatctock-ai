# --- LLM sağlayıcı seçimi (ADR-0005) ---
# "minimax" veya "gemini". Composition root bu değere göre adapter bağlar.
# Otomatik runtime fallback YOK (ADR-0005 § 3).
LLM_PROVIDER=minimax

# --- LLM: MiniMax (birincil, openai SDK + base_url override) ---
MINIMAX_API_KEY=replace_with_your_key
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_TIMEOUT_SECONDS=30

# --- LLM: Gemini (ikincil, google-genai SDK) ---
# Google AI Studio'dan ücretsiz alınır.
GOOGLE_API_KEY=replace_with_your_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_SECONDS=30

# --- Persistans — ADR-0006 ---
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# --- Scheduler — ADR-0007 (cron ifadeleri Settings'ten okunur) ---
SCHEDULER_STOCK_CHECK_CRON=0 * * * *
SCHEDULER_SHIPPING_CHECK_CRON=0 * * * *
SCHEDULER_MORNING_BRIEFING_CRON=0 8 * * *

# --- Notifier: Telegram — ADR-0008 ---
TELEGRAM_BOT_TOKEN=replace_with_your_token
TELEGRAM_CHAT_ID=replace_with_chat_id

# --- Agent loop — ADR-0009 ---
AGENT_MAX_TOOL_ITERATIONS=8

# --- Bildirim hedefleri ---
MANAGER_RECIPIENT=@manager
SUPPLIER_RECIPIENT=@tedarik

# --- Scheduler (true => job'lar lifespan'da başlar; CI ve dev default kapalı) ---
SCHEDULER_ENABLED=false
